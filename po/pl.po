msgid "Systemd Manager Neo"
msgstr "Menedżer Systemd Neo"

msgid "Settings"
msgstr "Ustawienia"

msgid "List is empty. Open Settings."
msgstr "Lista jest pusta. Otwórz Ustawienia."

msgid "FAILED"
msgstr "BŁĄD"

msgid "Terminal emulator not found!"
msgstr "Nie znaleziono emulatora terminala!"

msgid "Restarting: %s"
msgstr "Ponowne uruchamianie: %s"

msgid "Restarted: %s"
msgstr "Ponownie uruchomiono: %s"

msgid "Error restarting: %s"
msgstr "Błąd ponownego uruchamiania: %s"

msgid "Started: %s"
msgstr "Uruchomiono: %s"

msgid "Stopped: %s"
msgstr "Zatrzymano: %s"

msgid "Error: Access denied or cancelled"
msgstr "Błąd: Odmowa dostępu lub anulowano"

msgid "System"
msgstr "Systemowe"

msgid "User"
msgstr "Użytkownika"

msgid "State"
msgstr "Stan"

msgid "Favorite Services"
msgstr "Ulubione usługi"

msgid "Manage and reorder your pinned services."
msgstr "Zarządzaj i zmieniaj kolejność przypiętych usług."

msgid "Available Services"
msgstr "Dostępne usługi"

msgid "Search and add services to your favorites."
msgstr "Wyszukaj i dodaj usługi do ulubionych."

msgid "Search services..."
msgstr "Szukaj usług..."

msgid "No favorites added yet."
msgstr "Nie dodano jeszcze ulubionych."

msgid "...and %d more"
msgstr "...i %d więcej"

msgid "Use search to find specific services."
msgstr "Użyj wyszukiwania, aby znaleźć konkretne usługi."

msgid "All"
msgstr "Wszystkie"

msgid "Enabled"
msgstr "Włączone"

msgid "Disabled"
msgstr "Wyłączone"

msgid "Load next %d services"
msgstr "Wczytaj kolejne %d usług"

msgid "Load More"
msgstr "Wczytaj więcej"

msgid "Load All"
msgstr "Wczytaj wszystko"

msgid "You can load more or show the full list at once."
msgstr "Możesz wczytać więcej lub wyświetlić całą listę naraz."

msgid "Services"
msgstr "Usługi"

msgid "Groups"
msgstr "Grupy"

