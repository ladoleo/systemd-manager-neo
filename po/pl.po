msgstr "Brak ulubionych usług do dodania. Przejdź najpierw do zakładki Usługi."

msgid "Remove this group"
msgstr "Usuń tę grupę"

msgid "Delete"
msgstr "Usuń"

msgid "Start All"
msgstr "Uruchom wszystkie"

msgid "Stop All"
msgstr "Zatrzymaj wszystkie"

msgid "Starting group: %s"
msgstr "Uruchamianie grupy: %s"

msgid "Group started: %s (%d/%d)"
msgstr "Uruchomiono grupę: %s (%d/%d)"

msgid "Stopping group: %s"
msgstr "Zatrzymywanie grupy: %s"

msgid "Group stopped: %s (%d/%d)"
msgstr "Zatrzymano grupę: %s (%d/%d)"