msgid "Systemd Manager Neo"
msgstr "Systemd Manager Neo"

msgid "Settings"
msgstr "Nastavenia"

msgid "List is empty. Open Settings."
msgstr "Zoznam je prázdny. Otvorte Nastavenia."

msgid "FAILED"
msgstr "ZLYHALO"

msgid "Terminal emulator not found!"
msgstr "Emulátor terminálu nebol nájdený!"

msgid "Restarting: %s"
msgstr "Spúšťa sa znova: %s"

msgid "Restarted: %s"
msgstr "Spustené znova: %s"

msgid "Error restarting: %s"
msgstr "Chyba pri reštartovaní: %s"

msgid "Started: %s"
msgstr "Spustené: %s"

msgid "Stopped: %s"
msgstr "Zastavené: %s"

msgid "Error: Access denied or cancelled"
msgstr "Chyba: Prístup odmietnutý alebo zrušený"

msgid "System"
msgstr "Systém"

msgid "User"
msgstr "Používateľ"

msgid "State"
msgstr "Stav"

msgid "Favorite Services"
msgstr "Obľúbené služby"

msgid "Manage and reorder your pinned services."
msgstr "Správa a zmena poradia pripnutých služieb."

msgid "Available Services"
msgstr "Dostupné služby"

msgid "Search and add services to your favorites."
msgstr "Vyhľadajte a pridajte služby k svojim obľúbeným."

msgid "Search services..."
msgstr "Hľadať služby..."

msgid "No favorites added yet."
msgstr "Zatiaľ neboli pridané žiadne obľúbené služby."

msgid "...and %d more"
msgstr "...a ďalších %d"

msgid "Use search to find specific services."
msgstr "Hľadajte konkrétne služby pomocou vyhľadávania."

msgid "All"
msgstr "Všetky"

msgid "Enabled"
msgstr "Povolené"

msgid "Disabled"
msgstr "Zakázané"

msgid "Load next %d services"
msgstr "Načítať ďalších %d služieb"

msgid "Load More"
msgstr "Načítať viac"

msgid "Load All"
msgstr "Načítať všetko"

msgid "You can load more or show the full list at once."
msgstr "Môžete načítať ďalšie alebo zobraziť celý zoznam naraz."

msgid "Services"
msgstr "Služby"

msgid "Groups"
msgstr "Skupiny"

msgid "Service Groups"
msgstr "Skupiny služieb"

msgid "Create groups to manage multiple services at once."
msgstr "Vytvorte skupiny na správu viacerých služieb naraz."

msgid "New group name..."
msgstr "Nový názov skupiny..."

msgid "Add Group"
msgstr "Pridať skupinu"

msgid "%d services attached"
msgstr "Pripojených %d služieb"

msgid "No favorite services to add. Go to Services tab first."
msgstr "Žiadne obľúbené služby na pridanie. Prejdite najskôr na kartu Služby."

msgid "Remove this group"
msgstr "Odstrániť túto skupinu"

msgid "Delete"
msgstr "Odstrániť"

msgid "Start All"
msgstr "Spustiť všetky"

msgid "Stop All"
msgstr "Zastaviť všetky"

msgid "Starting group: %s"
msgstr "Spúšťa sa skupina: %s"

msgid "Group started: %s (%d/%d)"
msgstr "Skupina spustená: %s (%d/%d)"

msgid "Stopping group: %s"
msgstr "Zastavuje sa skupina: %s"

msgid "Group stopped: %s (%d/%d)"
msgstr "Skupina zastavená: %s (%d/%d)"